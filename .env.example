# Kovio cloud configuration. All vars are prefixed KOVIO_.
# Copy to .env for local dev, or set as secrets in production.

# --- Core ---------------------------------------------------------------------
KOVIO_SERVICE_NAME=kovio-cloud
# "dev"/"development"/"local"/"test" => pretty logs; anything else => JSON logs.
KOVIO_ENVIRONMENT=dev

# --- Database -----------------------------------------------------------------
# Async SQLAlchemy URL (asyncpg driver). Prod = Supabase transaction pooler.
KOVIO_DATABASE_URL=postgresql+asyncpg://kovio:kovio@localhost:5432/kovio
# DEV ONLY: create tables on startup (local Postgres has none). NEVER true in prod.
KOVIO_DEV_AUTO_CREATE_TABLES=false

# --- Auth ---------------------------------------------------------------------
# Server-side pepper mixed into the SHA256 API-key hash. MUST be set in prod.
KOVIO_KEY_PEPPER=kovio-dev-pepper-change-in-prod
# Supabase Auth JWT secret (HS256) for verifying web-app user sessions.
# Dashboard: Project Settings → API → JWT Secret. Dev can use any string as long
# as the JWTs you mint locally are signed with the same value.
KOVIO_SUPABASE_JWT_SECRET=local-test-secret
# Supabase project URL — used to fetch the JWKS for verifying ES256/RS256
# (asymmetric) session tokens, which is what real magic-link logins use.
KOVIO_SUPABASE_URL=https://your-project-ref.supabase.co

# --- Spend processor ----------------------------------------------------------
# Background job that costs ad_played events into impressions.
KOVIO_SPEND_PROCESSOR_ENABLED=true
KOVIO_SPEND_PROCESSOR_INTERVAL_SECONDS=60

# --- HTTP server --------------------------------------------------------------
KOVIO_HOST=0.0.0.0
KOVIO_PORT=8080

# --- CORS (JSON array) --------------------------------------------------------
KOVIO_CORS_ORIGINS=["https://kovio.dev","https://app.kovio.dev","http://localhost:3000"]
